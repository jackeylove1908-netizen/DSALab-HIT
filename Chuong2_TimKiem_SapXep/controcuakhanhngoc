//cout << *ptr;

// ví dụ chạy thử
#include <iostream>
using namespace std;

int main() {
    int a;          // khai báo biến a bất kì
    int* p;         // khai báo con trỏ p

    cout << "Nhap gia tri cua a: ";
    cin >> a;       // nhập giá trị bất kỳ cho a

    p = &a;         // p lưu địa chỉ của a

    cout << "Gia tri cua a: " << a << endl;
    cout << "Dia chi cua a: " << &a << endl;
    cout << "Gia tri cua p (dia chi cua a): " << p << endl;
    cout << "Gia tri ma p tro toi: " << *p << endl;

    return 0;
}
